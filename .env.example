# Camino Sanctus — prayer-app ENV template
# Copy to .env and fill in values.
# .env is git-ignored — NEVER commit real credentials.

# ─── App mode ──────────────────────────────────────────────────────────────────
# mock  = fully offline, no accounts needed (default for dev)
# live  = real Supabase + RevenueCat + Edge Function
EXPO_PUBLIC_APP_MODE=mock

# ─── Supabase (live mode only — 🔒 needs Supabase Pro account) ─────────────────
# https://supabase.com/dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── RevenueCat (live mode only — 🔒 needs RevenueCat account) ─────────────────
# https://app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-android-public-key-here
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your-ios-public-key-here

# ─── Sentry (optional, live mode) ──────────────────────────────────────────────
# EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project

# ─── PostHog analytics (optional, live mode) ───────────────────────────────────
# EXPO_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
